{
    "name": "jerryxf",
    "version": "1.0.0",
    "type": "module",
    "packageManager": "pnpm@11.1.3",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "cross-env NODE_ENV=development vite --host",
        "prebuild": "pnpm install && pnpm run lint",
        "build": "tsc -b && vite build",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 8",
        "lint:fix": "eslint . --report-unused-disable-directives --fix",
        "type-check": "tsc --noEmit",
        "preview": "vite preview",
        "start": "cross-env NODE_ENV=production serve -s dist -l 3000",
        "test": "echo \"Error: no test specified\" && exit 1",
        "analyze": "pnpm run build && npx vite-bundle-analyzer"
    },
    "dependencies": {
        "@fontsource-variable/outfit": "^5.2.8",
        "@gsap/react": "^2.1.2",
        "@types/smoothie": "^1.29.1",
        "baffle": "^0.3.6",
        "cross-env": "^10.1.0",
        "d3": "^7.9.0",
        "framer-motion": "^12.38.0",
        "gsap": "^3.15.0",
        "lucide-react": "^1.14.0",
        "motion": "^12.38.0",
        "papaparse": "^5.5.3",
        "plotly.js": "^3.5.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-helmet-async": "^3.0.0",
        "react-plotly.js": "^2.6.0",
        "react-router-dom": "^7.14.1",
        "sass": "^1.99.0",
        "serve": "^14.2.6",
        "smoothie": "^1.36.1",
        "split-type": "^0.3.4"
    },
    "devDependencies": {
        "@types/d3": "^7.4.3",
        "@types/node": "^25.6.0",
        "@types/papaparse": "^5.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-plotly.js": "^2.6.4",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.7.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.8"
    }
}
